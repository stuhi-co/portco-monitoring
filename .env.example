# ── Required API Keys ─────────────────────────────────────────────────────────

# Exa — search & company enrichment (get yours at https://dashboard.exa.ai/api-keys)
EXA_API_KEY=

# Anthropic — Claude for PE analysis (get yours at https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Resend — email delivery (get yours at https://resend.com/api-keys)
RESEND_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────

# Postgres credentials — used by both docker-compose and the backend.
# Defaults below work out of the box for local dev. Change for production.
POSTGRES_USER=portco
POSTGRES_PASSWORD=portco
POSTGRES_DB=portco_monitoring

# Full connection string — used by the backend directly.
# For local dev (no Docker): keep as-is. Docker Compose overrides host to "db".
DATABASE_URL=postgresql+asyncpg://portco:portco@localhost:5432/portco_monitoring

# ── Optional Overrides ────────────────────────────────────────────────────────

# Sender address for digest emails (must match your Resend verified domain)
# EMAIL_FROM=Ana Llana <ana@stuhi.co>

# Public URL of your app (used for unsubscribe links in emails)
# APP_BASE_URL=http://localhost:8000

# CORS — comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=["http://localhost:3000"]

# Scheduler: when to send digests (UTC). Default = Monday 4:00 PM
# DIGEST_CRON_HOUR=16
# DIGEST_CRON_DAY_OF_WEEK=mon

# Pipeline tuning
# RELEVANCE_THRESHOLD=6.0
# EXA_RESULTS_PER_QUERY=10
# MAX_DEVELOPMENTS_PER_COMPANY=5
# MAX_KEY_DEVELOPMENTS=3
# MAX_NOTABLE_DEVELOPMENTS=2
# MAX_COMPANIES_PER_SUBSCRIPTION=10
# DIGEST_COOLDOWN_HOURS=24